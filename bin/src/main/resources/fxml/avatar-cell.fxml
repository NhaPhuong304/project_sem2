<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.shape.Circle?>
<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.aptech.projectmgmt.controller.AvatarCellController"
            prefWidth="40.0" prefHeight="32.0">

    <ImageView fx:id="avatarImageView"
               fitWidth="28.0"
               fitHeight="28.0"
               layoutX="6.0"
               layoutY="2.0"
               pickOnBounds="true"
               preserveRatio="false"
               smooth="true">
        <clip>
            <Circle centerX="14.0" centerY="14.0" radius="14.0" />
        </clip>
    </ImageView>
</AnchorPane>
