<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.aptech.projectmgmt.controller.student.MyProjectListController"
            prefWidth="880" prefHeight="620">

    <Label text="Du an cua toi"
           layoutX="20" layoutY="20"
           style="-fx-font-size: 16; -fx-font-weight: bold;" />

    <TableView fx:id="projectTable"
               layoutX="20" layoutY="55"
               prefWidth="840" prefHeight="540">
        <columns>
            <TableColumn fx:id="projectNameColumn" text="Ten project" prefWidth="220.0" />
            <TableColumn fx:id="semesterColumn" text="Hoc ky" prefWidth="100.0" />
            <TableColumn fx:id="supervisorColumn" text="Thay huong dan" prefWidth="150.0" />
            <TableColumn fx:id="dateRangeColumn" text="Thoi gian" prefWidth="220.0" />
            <TableColumn fx:id="statusColumn" text="Trang thai" prefWidth="90.0" />
            <TableColumn fx:id="roleColumn" text="Vai tro" prefWidth="120.0" />
        </columns>
    </TableView>
</AnchorPane>
