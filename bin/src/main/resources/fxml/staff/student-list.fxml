<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>

<AnchorPane prefHeight="620" prefWidth="880" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.aptech.projectmgmt.controller.staff.StudentListController">

    <Label fx:id="classNameLabel" layoutX="20" layoutY="20" style="-fx-font-size: 16; -fx-font-weight: bold;" text="Danh sach Sinh vien" />

    <HBox layoutX="20" layoutY="55" spacing="10">
        <Button fx:id="createAccountsBtn" text="Tao tai khoan tu dong cho ca lop" />
        <Button fx:id="addStudentBtn" text="+ Them sinh vien vao lop" />
    </HBox>

    <TableView fx:id="studentTable" layoutX="20" layoutY="95" prefHeight="500" prefWidth="840">
        <columns>
            <TableColumn fx:id="avatarColumn" prefWidth="80.0" text="Avatar" />
            <TableColumn fx:id="studentCodeColumn" prefWidth="120.0" text="Ma SV" />
            <TableColumn fx:id="fullNameColumn" prefWidth="190.0" text="Ho ten" />
            <TableColumn fx:id="emailColumn" prefWidth="250.0" text="Email" />
            <TableColumn fx:id="accountStatusColumn" prefWidth="198.28570556640625" text="Tai khoan" />
        </columns>
    </TableView>
</AnchorPane>
