<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.aptech.projectmgmt.controller.staff.TaskDetailController"
            prefWidth="680" prefHeight="500">

    <Label fx:id="taskTitleLabel"
           layoutX="20" layoutY="18"
           style="-fx-font-size: 16; -fx-font-weight: bold;" />

    <TextArea fx:id="taskDetailArea"
              layoutX="20" layoutY="55"
              prefWidth="640" prefHeight="425"
              editable="false" wrapText="true"
              AnchorPane.topAnchor="55.0"
              AnchorPane.rightAnchor="20.0"
              AnchorPane.bottomAnchor="20.0"
              AnchorPane.leftAnchor="20.0" />
</AnchorPane>
