<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>
<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.aptech.projectmgmt.controller.staff.ProjectDetailController"
            prefWidth="900" prefHeight="650">

    <TabPane fx:id="tabPane"
             layoutX="10" layoutY="10"
             prefWidth="880" prefHeight="630">

        <Tab text="Thong tin Project" closable="false">
            <AnchorPane>
                <Label text="Ten project:" layoutX="20" layoutY="20" />
                <TextField fx:id="projectNameField" layoutX="20" layoutY="40" prefWidth="320" />

                <Label text="Hoc ky:" layoutX="370" layoutY="20" />
                <TextField fx:id="semesterField" layoutX="370" layoutY="40" prefWidth="160" />

                <Label text="Thay huong dan:" layoutX="560" layoutY="20" />
                <TextField fx:id="supervisorField" layoutX="560" layoutY="40" prefWidth="280" editable="false" />

                <Label text="Ngay bat dau:" layoutX="20" layoutY="95" />
                <DatePicker fx:id="startDatePicker" layoutX="20" layoutY="115" prefWidth="180" />

                <Label text="Ngay ket thuc:" layoutX="220" layoutY="95" />
                <DatePicker fx:id="endDatePicker" layoutX="220" layoutY="115" prefWidth="180" />

                <Label text="Ngay bao cao:" layoutX="420" layoutY="95" />
                <DatePicker fx:id="reportDatePicker" layoutX="420" layoutY="115" prefWidth="180" />

                <Label text="Mo ta:" layoutX="20" layoutY="170" />
                <TextArea fx:id="descriptionArea" layoutX="20" layoutY="190" prefWidth="820" prefHeight="320" wrapText="true" />

                <Button fx:id="editBtn" text="Chinh sua" layoutX="20" layoutY="535" />
                <Button fx:id="saveBtn" text="Luu" layoutX="110" layoutY="535" />
                <Button fx:id="cancelBtn" text="Huy" layoutX="170" layoutY="535" />
                <Button fx:id="completeBtn" text="Danh dau hoan thanh" layoutX="240" layoutY="535" />
            </AnchorPane>
        </Tab>

        <Tab text="Nhom" closable="false">
            <AnchorPane>
                <Button fx:id="addGroupBtn"
                        text="+ Tao nhom"
                        layoutX="10" layoutY="10" />
                <ListView fx:id="groupListView"
                          layoutX="10" layoutY="50"
                          prefWidth="860" prefHeight="540"
                          AnchorPane.topAnchor="50.0"
                          AnchorPane.rightAnchor="10.0"
                          AnchorPane.bottomAnchor="10.0"
                          AnchorPane.leftAnchor="10.0" />
            </AnchorPane>
        </Tab>

        <Tab text="Cong viec" closable="false">
            <AnchorPane>
                <Label text="Chon nhom:" layoutX="20" layoutY="20" />
                <ComboBox fx:id="taskGroupCombo" layoutX="20" layoutY="45" prefWidth="280" />
                <Label text="Trang thai:" layoutX="330" layoutY="20" />
                <ComboBox fx:id="taskStatusFilterCombo" layoutX="330" layoutY="45" prefWidth="220" />
                <StackPane fx:id="taskContentPane"
                           layoutX="20" layoutY="95"
                           prefWidth="840" prefHeight="505"
                           AnchorPane.topAnchor="95.0"
                           AnchorPane.rightAnchor="20.0"
                           AnchorPane.bottomAnchor="20.0"
                           AnchorPane.leftAnchor="20.0">
                    <Label fx:id="taskPlaceholderLabel" text="Chon nhom de xem danh sach cong viec" />
                </StackPane>
            </AnchorPane>
        </Tab>
    </TabPane>
</AnchorPane>
