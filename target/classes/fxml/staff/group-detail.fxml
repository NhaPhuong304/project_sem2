<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.aptech.projectmgmt.controller.staff.GroupDetailController"
            prefWidth="800" prefHeight="500">

    <Label fx:id="groupNameLabel" text="Chi tiet Nhom"
           layoutX="20" layoutY="20"
           style="-fx-font-size: 16; -fx-font-weight: bold;" />

    <Button fx:id="addMemberBtn" text="+ Them sinh vien" layoutX="640" layoutY="18" />

    <TableView fx:id="memberTable"
               layoutX="20" layoutY="60"
               prefWidth="760" prefHeight="410">
        <columns>
            <TableColumn fx:id="avatarColumn" text="Avatar" prefWidth="80.0" />
            <TableColumn fx:id="studentCodeColumn" text="Ma SV" prefWidth="100.0" />
            <TableColumn fx:id="studentNameColumn" text="Ho ten" prefWidth="170.0" />
            <TableColumn fx:id="roleColumn" text="Vai tro" prefWidth="100.0" />
            <TableColumn fx:id="statusColumn" text="Trang thai" prefWidth="130.0" />
            <TableColumn fx:id="abandonCountColumn" text="So lan bo task" prefWidth="110.0" />
            <TableColumn fx:id="actionColumn" text="Hanh dong" prefWidth="100.0" />
        </columns>
    </TableView>
</AnchorPane>
