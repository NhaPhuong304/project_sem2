<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
	xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="com.aptech.projectmgmt.controller.staff.StudentManagementController"
	prefWidth="880" prefHeight="620">

	<HBox layoutX="20" layoutY="20" spacing="10">
		<Button fx:id="addStudentBtn" text="+ Them sinh vien" />
	</HBox>

	<TableView fx:id="studentTable" layoutX="20" layoutY="65"
		prefWidth="840" prefHeight="530">
		<columns>
			<TableColumn fx:id="avatarColumn" text="Avatar"
				prefWidth="70.0" />
			<TableColumn fx:id="studentCodeColumn" text="Ma SV"
				prefWidth="90.0" />
			<TableColumn fx:id="fullNameColumn" text="Ho ten"
				prefWidth="150.0" />
			<TableColumn fx:id="emailColumn" text="Email"
				prefWidth="180.0" />
			<TableColumn fx:id="classNameColumn" text="Lop"
				prefWidth="100.0" />
			<TableColumn fx:id="accountStatusColumn" text="Tai khoan"
				prefWidth="100.0" />
			<TableColumn fx:id="actionColumn" text="Action"
				prefWidth="150.0" />
		</columns>
	</TableView>
</AnchorPane>