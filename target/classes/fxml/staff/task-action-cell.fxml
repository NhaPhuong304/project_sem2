    <HBox spacing="4.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <Button fx:id="messageButton" mnemonicParsing="false" prefHeight="30.0" prefWidth="92.0" styleClass="table-action-button" text="Nhac nho" textAlignment="CENTER">
         <opaqueInsets>
            <Insets top="1.0" />
         </opaqueInsets></Button>
        <Button fx:id="detailButton" mnemonicParsing="false" prefHeight="30.0" prefWidth="85.0" styleClass="table-action-button" text="Chi tiet" textAlignment="CENTER">
         <opaqueInsets>
            <Insets />
         </opaqueInsets></Button>
    </HBox>
</AnchorPane>
