<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>

<AnchorPane prefHeight="620.0" prefWidth="880.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.aptech.projectmgmt.controller.staff.ClassListController">

    <HBox layoutX="20.0" layoutY="20.0" spacing="10.0">
        <TextField fx:id="searchField"
                   prefWidth="260.0"
                   prefHeight="34.0"
                   promptText="Tim kiem theo ten lop..." />
        <Button fx:id="addClassBtn"
                text="+ Them lop moi"
                prefWidth="120.0"
                prefHeight="34.0" />
    </HBox>

    <TableView fx:id="classTable"
               layoutX="20.0" layoutY="65.0"
               prefWidth="840.0" prefHeight="530.0">
        <columns>
            <TableColumn fx:id="noColumn" text="No." prefWidth="60.0" />
            <TableColumn fx:id="classNameColumn" text="Ten lop" prefWidth="220.0" />
            <TableColumn fx:id="academicYearColumn" text="Nam hoc" prefWidth="120.0" />
            <TableColumn fx:id="studentCountColumn" text="So SV" prefWidth="90.0" />
            <TableColumn fx:id="createdAtColumn" text="Ngay tao" prefWidth="180.0" />
            <TableColumn fx:id="actionColumn" text="Hanh dong" prefWidth="170.0" />
        </columns>
    </TableView>
</AnchorPane>