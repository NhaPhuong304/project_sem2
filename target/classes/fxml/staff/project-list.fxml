<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>

<AnchorPane prefHeight="620" prefWidth="880" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.aptech.projectmgmt.controller.staff.ProjectListController">

    <HBox layoutX="20" layoutY="20" spacing="10">
        <ComboBox fx:id="classCombo" prefWidth="250" promptText="Chon lop..." />
        <ComboBox fx:id="semesterCombo" prefWidth="200" promptText="Chon hoc ky..." />
        <Button fx:id="addProjectBtn" text="+ Tao Project moi" />
    </HBox>

    <TableView fx:id="projectTable" layoutX="20" layoutY="65" prefHeight="530" prefWidth="840">
        <columns>
            <TableColumn fx:id="projectNameColumn" prefWidth="200.0" text="Ten project" />
            <TableColumn fx:id="semesterColumn" prefWidth="80.0" text="Hoc ky" />
            <TableColumn fx:id="supervisorColumn" prefWidth="150.0" text="Thay huong dan" />
            <TableColumn fx:id="startDateColumn" prefWidth="100.0" text="Bat dau" />
            <TableColumn fx:id="endDateColumn" prefWidth="100.0" text="Ket thuc" />
            <TableColumn fx:id="statusColumn" prefWidth="120.0" text="Trang thai" />
            <TableColumn fx:id="actionColumn" prefWidth="88.57135009765625" text="Chi tiet" />
        </columns>
    </TableView>
</AnchorPane>
