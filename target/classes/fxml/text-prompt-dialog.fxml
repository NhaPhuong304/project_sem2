<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.aptech.projectmgmt.controller.TextPromptDialogController"
            prefWidth="500.0" prefHeight="260.0">

    <Label fx:id="headerLabel"
           layoutX="20.0" layoutY="18.0"
           wrapText="true"
           style="-fx-font-size: 14; -fx-font-weight: bold;"
           AnchorPane.topAnchor="18.0"
           AnchorPane.leftAnchor="20.0"
           AnchorPane.rightAnchor="20.0" />

    <Label fx:id="promptLabel"
           layoutX="20.0" layoutY="58.0"
           text="Noi dung"
           AnchorPane.topAnchor="58.0"
           AnchorPane.leftAnchor="20.0" />

    <TextArea fx:id="contentArea"
              layoutX="20.0" layoutY="82.0"
              prefWidth="460.0" prefHeight="150.0"
              wrapText="true"
              AnchorPane.topAnchor="82.0"
              AnchorPane.rightAnchor="20.0"
              AnchorPane.bottomAnchor="20.0"
              AnchorPane.leftAnchor="20.0" />
</AnchorPane>
