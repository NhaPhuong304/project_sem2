<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<HBox prefHeight="500.0" prefWidth="1000.0" stylesheets="@/css/login.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.aptech.projectmgmt.controller.LoginController">

    <!-- LEFT SIDE -->
    <StackPane styleClass="left-panel" HBox.hgrow="ALWAYS">
        <VBox alignment="CENTER" spacing="8" stylesheets="@../css/login.css">
            <HBox alignment="CENTER" spacing="0">
                <Text styleClass="title-dark" text="Student " />
                <Text styleClass="title-accent" text="Project" />
            </HBox>

            <Text styleClass="title-dark" text="Management" />
            <Text styleClass="title-light" text="System" />
        </VBox>
    </StackPane>

    <!-- RIGHT SIDE -->
    <VBox alignment="CENTER" prefWidth="450.0" spacing="18" styleClass="right-panel" stylesheets="@../css/login.css">

        <Label styleClass="welcome-text" text="Welcome Back" />

        <TextField fx:id="usernameField" maxWidth="300.0" minWidth="300.0" prefHeight="44.0" prefWidth="300.0" promptText="Username" />

        <StackPane alignment="CENTER_RIGHT" maxWidth="300.0" minWidth="300.0" prefHeight="44.0" prefWidth="300.0">

            <PasswordField fx:id="passwordField" maxWidth="300.0" minWidth="300.0" prefHeight="44.0" prefWidth="300.0" promptText="Password" />

            <TextField fx:id="visiblePasswordField" managed="false" maxWidth="300.0" minWidth="300.0" prefHeight="44.0" prefWidth="300.0" promptText="Password" visible="false" />

            <Button fx:id="togglePasswordBtn" styleClass="eye-btn" text="👁" />
        </StackPane>

        <Label fx:id="errorLabel" maxWidth="300.0" minWidth="300.0" prefWidth="300.0" styleClass="error-label" visible="false" />

        <Button fx:id="loginBtn" prefHeight="42.0" prefWidth="180.0" styleClass="login-btn" text="Login" />

        <Hyperlink fx:id="forgotPasswordLink" styleClass="register-link" text="Forgot password?" />
    </VBox>

</HBox>
