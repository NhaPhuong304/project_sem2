<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<HBox prefHeight="560.0" prefWidth="1000.0" stylesheets="@/css/otp.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.aptech.projectmgmt.controller.OtpController">

    <!-- LEFT SIDE -->
    <StackPane styleClass="left-panel" HBox.hgrow="ALWAYS">
        <VBox alignment="CENTER" spacing="8" stylesheets="@../css/otp.css">
            <HBox alignment="CENTER" spacing="0">
                <Text styleClass="title-dark" text="Student " />
                <Text styleClass="title-accent" text="Project" />
            </HBox>

            <Text styleClass="title-dark" text="Management" />
            <Text styleClass="title-light" text="System" />
        </VBox>
    </StackPane>

    <!-- RIGHT SIDE -->
    <VBox alignment="CENTER" prefWidth="460.0" spacing="14" styleClass="right-panel" stylesheets="@../css/otp.css">

        <Label styleClass="welcome-text" text="OTP Verification" />

        <VBox maxWidth="320" spacing="4">
            <Label styleClass="form-label" text="OTP sent to:" />
            <Label fx:id="emailLabel" styleClass="email-label" text="a***@gmail.com" />
        </VBox>

        <VBox maxWidth="320" spacing="6">
            <Label styleClass="form-label" text="Enter OTP (6 digits)" />
            <TextField fx:id="otpField" maxWidth="320.0" minWidth="320.0" prefHeight="44.0" prefWidth="320.0" promptText="Enter OTP" />
        </VBox>

        <HBox alignment="CENTER_LEFT" maxWidth="320" spacing="12">
            <Button fx:id="resendBtn" prefHeight="38.0" prefWidth="110.0" styleClass="secondary-btn" text="Resend" />

            <Label fx:id="countdownLabel" styleClass="countdown-label" text="" />
        </HBox>

        <Label fx:id="expiryLabel" maxWidth="320" styleClass="expiry-label" text="" wrapText="true" />

        <VBox maxWidth="320" spacing="6">
            <Label styleClass="form-label" text="New Password" />
            <PasswordField fx:id="newPasswordField" maxWidth="320.0" minWidth="320.0" prefHeight="44.0" prefWidth="320.0" promptText="Enter new password" />
        </VBox>

        <VBox maxWidth="320" spacing="6">
            <Label styleClass="form-label" text="Confirm Password" />
            <PasswordField fx:id="confirmPasswordField" maxWidth="320.0" minWidth="320.0" prefHeight="44.0" prefWidth="320.0" promptText="Confirm new password" />
        </VBox>

        <Button fx:id="confirmBtn" prefHeight="42.0" prefWidth="180.0" styleClass="login-btn" text="Confirm" />
    </VBox>

</HBox>
