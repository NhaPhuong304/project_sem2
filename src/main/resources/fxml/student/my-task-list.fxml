            <TableColumn fx:id="statusColumn" prefWidth="110.0" text="Trang thai" />
            <TableColumn fx:id="assignedToColumn" prefWidth="130.0" text="Nguoi thuc hien" />
            <TableColumn fx:id="reviewedByColumn" prefWidth="189.7142333984375" text="Nguoi kiem tra" />
            <TableColumn fx:id="revisionNoteColumn" prefWidth="160.5714111328125" text="Noi dung chinh sua" />
            <TableColumn fx:id="actionColumn" prefWidth="200.0" text="Hanh dong" />
