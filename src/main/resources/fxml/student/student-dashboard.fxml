<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.aptech.projectmgmt.controller.student.StudentDashboardController"
            prefWidth="1100" prefHeight="700">

    <top>
        <AnchorPane style="-fx-background-color: #2e7d32;" prefHeight="60">
            <HBox spacing="10.0"
                  alignment="CENTER_LEFT"
                  AnchorPane.leftAnchor="20.0"
                  AnchorPane.topAnchor="10.0">
                <ImageView fitWidth="180.0"
                           fitHeight="180.0"
                           preserveRatio="true"
                           smooth="true">
                    <image>
                        <Image url="@/images/aptech.png" />
                    </image>
                </ImageView>
                <Label text="He thong Quan ly Du an - Sinh vien"
                       style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;" />
            </HBox>
            <HBox spacing="12.0"
                  alignment="CENTER_RIGHT"
                  AnchorPane.topAnchor="10.0"
                  AnchorPane.rightAnchor="20.0">
                <Label fx:id="studentNameLabel" text="Sinh vien"
                       style="-fx-text-fill: white;" />
                <Label fx:id="msgBadge" text="0"
                       styleClass="badge" visible="false" />
                <ImageView fx:id="avatarImageView"
                           styleClass="clickable-avatar"
                           fitWidth="40.0"
                           fitHeight="40.0"
                           preserveRatio="false"
                           smooth="true">
                    <clip>
                        <Circle centerX="20.0" centerY="20.0" radius="20.0" />
                    </clip>
                </ImageView>
                <Button fx:id="logoutBtn" text="Dang xuat" />
            </HBox>
        </AnchorPane>
    </top>

    <left>
        <VBox style="-fx-background-color: #e8f5e9;" prefWidth="200" spacing="5">
            <Button fx:id="myProjectsBtn" text="Du an cua toi" prefWidth="200" prefHeight="40"
                    onAction="#onMyProjectsClick" styleClass="sidebar-btn" />
            <Button fx:id="inboxBtn" text="Hop thu den" prefWidth="200" prefHeight="40"
                    onAction="#onInboxClick" styleClass="sidebar-btn" />
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: white;" />
    </center>
</BorderPane>
