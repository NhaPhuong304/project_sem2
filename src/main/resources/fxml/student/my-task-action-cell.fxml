<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.aptech.projectmgmt.controller.student.MyTaskActionCellController"
            prefWidth="520.0" prefHeight="30.0">

    <HBox spacing="4.0"
          AnchorPane.topAnchor="0.0"
          AnchorPane.rightAnchor="0.0"
          AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0">
        <Button fx:id="startButton"
                mnemonicParsing="false"
                text="Bat dau"
                visible="false"
                managed="false"
                styleClass="table-action-button">
            <tooltip>
                <Tooltip fx:id="startTooltip" text="Chua den gio bat dau" />
            </tooltip>
        </Button>
        <Button fx:id="submitReviewButton"
                mnemonicParsing="false"
                text="Gui kiem tra"
                visible="false"
                managed="false"
                styleClass="table-action-button" />
        <Button fx:id="requestRevisionButton"
                mnemonicParsing="false"
                text="Yeu cau chinh sua"
                visible="false"
                managed="false"
                styleClass="table-action-button" />
        <Button fx:id="completeButton"
                mnemonicParsing="false"
                text="Xac nhan hoan thanh"
                visible="false"
                managed="false"
                styleClass="table-action-button" />
        <Button fx:id="resubmitButton"
                mnemonicParsing="false"
                text="Gui lai kiem tra"
                visible="false"
                managed="false"
                styleClass="table-action-button" />
        <Button fx:id="detailButton"
                mnemonicParsing="false"
                text="Chi tiet"
                visible="false"
                managed="false"
                styleClass="table-action-button" />
    </HBox>
</AnchorPane>
