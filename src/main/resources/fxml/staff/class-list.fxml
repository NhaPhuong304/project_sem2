<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>

<AnchorPane prefHeight="620" prefWidth="880" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.aptech.projectmgmt.controller.staff.ClassListController">

    <HBox layoutX="20" layoutY="20" spacing="10">
        <TextField fx:id="searchField" prefWidth="300" promptText="Tim kiem theo ten lop..." />
        <Button fx:id="addClassBtn" text="+ Them lop moi" />
    </HBox>

    <TableView fx:id="classTable" layoutX="20" layoutY="65" prefHeight="530" prefWidth="840">
        <columns>
            <TableColumn fx:id="noColumn" prefWidth="60.0" text="No." />
            <TableColumn fx:id="classNameColumn" prefWidth="250.0" text="Ten lop" />
            <!-- Đã xóa cột Học kỳ tại đây -->
            <TableColumn fx:id="academicYearColumn" prefWidth="130.0" text="Nam hoc" />
            <TableColumn fx:id="studentCountColumn" prefWidth="100.0" text="So SV" />
            <TableColumn fx:id="createdAtColumn" prefWidth="150.0" text="Ngay tao" />
            <TableColumn fx:id="actionColumn" prefWidth="148.0" text="Hanh dong" />
        </columns>
    </TableView>
</AnchorPane>