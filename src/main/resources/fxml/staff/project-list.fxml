<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>

<AnchorPane prefHeight="620" prefWidth="880" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.aptech.projectmgmt.controller.staff.ProjectListController">

    <HBox layoutX="20" layoutY="20" spacing="10">
        <ComboBox fx:id="classCombo" prefWidth="300" promptText="Chon lop..." />
      
        <Button fx:id="addProjectBtn" text="+ Tao Project moi" />
    </HBox>

    <TableView fx:id="projectTable" layoutX="20" layoutY="65" prefHeight="530" prefWidth="840">
        <columns>
            <TableColumn fx:id="projectNameColumn" prefWidth="240.0" text="Ten project" />
            <!-- Đã xóa cột Học kỳ tại đây -->
            <TableColumn fx:id="supervisorColumn" prefWidth="180.0" text="Thay huong dan" />
            <TableColumn fx:id="startDateColumn" prefWidth="110.0" text="Bat dau" />
            <TableColumn fx:id="endDateColumn" prefWidth="110.0" text="Ket thuc" />
            <TableColumn fx:id="statusColumn" prefWidth="110.0" text="Trang thai" />
            <TableColumn fx:id="actionColumn" prefWidth="88.5" text="Chi tiet" />
        </columns>
    </TableView>
</AnchorPane>