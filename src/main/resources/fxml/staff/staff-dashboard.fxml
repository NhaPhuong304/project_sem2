<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane prefHeight="720.0" prefWidth="1180.0" styleClass="dashboard-root" stylesheets="@../../css/staff.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.aptech.projectmgmt.controller.staff.StaffDashboardController">

	<left>
		<VBox prefWidth="240.0" spacing="14.0" styleClass="sidebar">
			<padding>
				<Insets bottom="24.0" left="18.0" right="18.0" top="24.0" />
			</padding>

			<VBox spacing="10.0" style="-fx-padding: 18 0 0 0;">
				<Button fx:id="classListBtn" onAction="#onClassListClick" prefHeight="44.0" prefWidth="204.0" styleClass="sidebar-btn" text="Quan ly Lop" />

				<Button fx:id="projectListBtn" onAction="#onProjectListClick" prefHeight="44.0" prefWidth="204.0" styleClass="sidebar-btn" text="Quan ly Project" />

				<Button fx:id="studentManagementBtn" onAction="#onStudentManagementClick" prefHeight="44.0" prefWidth="204.0" styleClass="sidebar-btn" text="Quan ly Sinh vien" />

				<Button fx:id="teacherListBtn" onAction="#onTeacherListClick" prefHeight="44.0" prefWidth="204.0" styleClass="sidebar-btn" text="Quan ly Giao vien" />
			</VBox>
		</VBox>
	</left>

	<top>
		<AnchorPane prefHeight="78.0" styleClass="topbar">
			<HBox alignment="CENTER_LEFT" spacing="12.0" AnchorPane.leftAnchor="28.0" AnchorPane.topAnchor="12.0">

				<StackPane styleClass="top-logo-wrap">
					<ImageView fitHeight="34.0" fitWidth="34.0" preserveRatio="true" smooth="true">
						<image>
							<Image url="@/images/aptech.png" />
						</image>
					</ImageView>
				</StackPane>

				<VBox spacing="2.0">
					<Label styleClass="topbar-title" text="Student Project" />
					<Label styleClass="topbar-subtitle" text="Management System" />
				</VBox>
			</HBox>

			<HBox alignment="CENTER_RIGHT" spacing="12.0" AnchorPane.rightAnchor="24.0" AnchorPane.topAnchor="15.0">

				<Label fx:id="staffNameLabel" styleClass="staff-name-label" text="Giao vu" />

				<ImageView fx:id="avatarImageView" fitHeight="42.0" fitWidth="42.0" preserveRatio="false" smooth="true" styleClass="clickable-avatar">
					<clip>
						<Circle centerX="21.0" centerY="21.0" radius="21.0" />
					</clip>
				</ImageView>

				<Button fx:id="logoutBtn" styleClass="logout-btn" text="Dang xuat" />
			</HBox>
		</AnchorPane>
	</top>

	<center>
		<StackPane styleClass="center-wrapper">
			<StackPane fx:id="contentArea" styleClass="content-card" />
		</StackPane>
	</center>
</BorderPane>
